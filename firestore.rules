rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function ownerEmail() { return "kelvinchen20000108@gmail.com"; }
    function isOwnerEmail(email) { return email in ["kelvinchen20000108@gmail.com", "clayton0220@gmail.com"]; }
    function isOwner() { return signedIn() && isOwnerEmail(request.auth.token.email); }
    function userDoc() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUserDoc() { return signedIn() && exists(userDoc()); }
    function role() { return hasUserDoc() ? get(userDoc()).data.role : "free"; }
    function isAdmin() { return isOwner() || role() == "admin" || role() == "super_admin"; }
    function isSuperAdmin() { return isOwner() || role() == "super_admin"; }
    function isOwnDoc(userId) { return signedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isOwnDoc(userId) || isAdmin();

      // 登入第一次建立個人檔案。Owner 可以建立 super_admin，其他人只能 free。
      allow create: if isOwnDoc(userId)
        && request.resource.data.email == request.auth.token.email
        && (
          (isOwnerEmail(request.auth.token.email)
            && request.resource.data.role == "super_admin"
            && request.resource.data.isOwner == true)
          ||
          (!isOwnerEmail(request.auth.token.email)
            && request.resource.data.role == "free"
            && !("isOwner" in request.resource.data))
        );

      // Owner 擁有所有 user 管理權。
      allow update: if isOwner();

      // Admin 可以調整一般用戶，但不可修改 owner、不可建立 super_admin、不可寫 isOwner。
      allow update: if isAdmin()
        && !isOwnerEmail(resource.data.email)
        && request.resource.data.email == resource.data.email
        && request.resource.data.role != "super_admin"
        && !("isOwner" in request.resource.data);

      allow delete: if isOwner() && !isOwnerEmail(resource.data.email);
    }

    match /analyses/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cache/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isOwner();
    }


    match /apiUsageDaily/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /apiUsageMonthly/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /jobs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /commissions/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isOwner();
    }

    match /agents/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isOwner();
    }

    // 邀請紀錄：登入用戶可建立，本人與 Admin 可讀
    match /invites/{id} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.inviterUid == request.auth.uid ||
        resource.data.inviteeUid == request.auth.uid
      ));
      allow create: if signedIn();
      allow update, delete: if isAdmin();
    }

    // 用戶端事件日誌（邀請、點擊等）
    match /clientEventsDaily/{id} {
      allow read: if isAdmin();
      allow write: if signedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

