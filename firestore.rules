rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function ownerEmail() { return "kelvinchen20000108@gmail.com"; }
    function isOwner() { return signedIn() && request.auth.token.email == ownerEmail(); }
    function userDoc() { return /databases/$(database)/documents/users/$(request.auth.uid); }
    function hasUserDoc() { return signedIn() && exists(userDoc()); }
    function role() { return hasUserDoc() ? get(userDoc()).data.role : "free"; }
    function isAdmin() { return isOwner() || role() == "admin" || role() == "super_admin"; }
    function isSuperAdmin() { return isOwner() || role() == "super_admin"; }
    function isOwnDoc(userId) { return signedIn() && request.auth.uid == userId; }

    match /users/{userId} {
      allow read: if isOwnDoc(userId) || isAdmin();

      // 登入第一次建立個人檔案。Owner 可以建立 super_admin，其他人只能 free。
      allow create: if isOwnDoc(userId)
        && request.resource.data.email == request.auth.token.email
        && (
          (request.auth.token.email == ownerEmail()
            && request.resource.data.role == "super_admin"
            && request.resource.data.isOwner == true)
          ||
          (request.auth.token.email != ownerEmail()
            && request.resource.data.role == "free"
            && !("isOwner" in request.resource.data))
        );

      // Owner 擁有所有 user 管理權。
      allow update: if isOwner();

      // Admin 可以調整一般用戶，但不可修改 owner、不可建立 super_admin、不可寫 isOwner。
      allow update: if isAdmin()
        && resource.data.email != ownerEmail()
        && request.resource.data.email == resource.data.email
        && request.resource.data.role != "super_admin"
        && !("isOwner" in request.resource.data);

      allow delete: if isOwner() && resource.data.email != ownerEmail();
    }

    match /analyses/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /cache/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isOwner();
    }


    match /apiUsageDaily/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /apiUsageMonthly/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /jobs/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /commissions/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isOwner();
    }

    match /agents/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
